{
  "name": "@ziyang-oyxy/markdown-preview-toolbox",
  "version": "0.0.10",
  "description": "Standalone markdown preview, export, and browse CLI tools",
  "bin": {
    "mkdp": "./bin/mkdp.js"
  },
  "files": [
    "bin/",
    "lib/",
    "assets/"
  ],
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "socket.io": "~2.4.0"
  },
  "peerDependencies": {
    "playwright": ">=1.30.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "license": "MIT",
  "scripts": {
    "prepublishOnly": "node -e \"if(!require('fs').existsSync('./assets/web/index.html')){console.error('assets not built');process.exit(1)}\""
  }
}
